# RUST_VERSION is intentionally NOT set here. The canonical source is
# rust-toolchain.toml's `channel`; consumers derive it via
# tools/scripts/get-rust-version.sh.

# zcashd Git tag (https://github.com/zcash/zcash/releases)
ZCASH_VERSION=6.20.0

ZEBRA_VERSION=5.1.0

# zcash-devtool git ref (https://github.com/zingolabs/zcash-devtool) —
# the wallet client driven by wallet-tests via zcash_local_net, built
# with `--features regtest_support`. Pinned to an exact `add_regtest`
# commit (not the branch name) so the image tag changes when the binary
# does — a moving branch ref leaves the tag stale and the rebuild reuses
# the old baked binary. Bump this hash as the coordinated client work
# (zingolabs/infrastructure#269) advances, then `makers build-image`.
# d820388 adds the `wallet get-info` command (round-3 spec P1).
DEVTOOL_VERSION=d820388db5ea66921ce8d7383e12c33f85f9396f
